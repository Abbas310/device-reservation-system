@{
    ViewBag.Title = "Devices Report";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Devices Report</title>

    <link rel="stylesheet"
          href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.6/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/Content/DevicesStyle.css" />
</head>
<body>

    <nav class="navbar navbar-default">
        <div class="container-fluid">

            <div class="navbar-header">
                <a class="navbar-brand" href="/Home/Index">Vanrise</a>
            </div>

            <ul class="nav navbar-nav">
                <li><a href="/Home/Index">Devices</a></li>
                <li><a href="/Home/Clients">Clients</a></li>
                <li><a href="/Home/PhoneNumbers">Phone Numbers</a></li>
                <li><a href="/Home/Reservations">Reservations</a></li>
                <li><a href="/Home/ClientsReport">Clients Report</a></li>
                <li><a href="/Home/DevicesReport">Devices Report</a></li>
            </ul>

        </div>
    </nav>

    <div ng-app="devicesReportApp" ng-controller="DevicesReportController" class="container" style="margin-top:30px;">

        <h1>Devices Report</h1>

        <div class="controls" style="margin-bottom:15px;">
            <label style="margin-right:8px;">Device:</label>
            <device-selector-optional ng-model="selectedDeviceId" placeholder="All Devices"></device-selector-optional>

            <label style="margin-left:14px; margin-right:8px;">Phone Reservation Status:</label>
            <select class="form-control"
                    style="display:inline-block; width:200px;"
                    ng-model="selectedStatus">
                <option value="">-- Select --</option>
                <option value="reserved">Reserved</option>
                <option value="unreserved">Unreserved</option>
            </select>

            <button class="btn btn-primary" style="margin-left:6px;" ng-click="search()">Search</button>
        </div>

        <table class="table table-bordered device-table" style="width:1100px;">
            <thead>
                <tr>
                    <th style="width:250px;">Device</th>
                    <th style="width:250px;">Phone Numbers Status</th>
                    <th>Number of Phone Numbers</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="r in rows">
                    <td>[[ r.DeviceName ]]</td>
                    <td>[[ r.Status ]]</td>
                    <td>[[ r.Count ]]</td>
                </tr>
            </tbody>
        </table>

    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.4.8/angular.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/angular-ui-bootstrap/0.14.3/ui-bootstrap-tpls.min.js"></script>

    <script src="~/Scripts/directives/deviceSelector.js"></script>
    <script src="~/Scripts/DevicesReportScript.js"></script>
    <script src="~/Scripts/directives/deviceSelectorOptional.js"></script>

</body>
</html>